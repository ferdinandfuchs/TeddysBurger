---
interface Review {
  author: string;
  text: string;
  rating: number;
  date?: string;
}

interface Props {
  reviews?: Review[];
}

const { reviews = [] } = Astro.props;
---

{reviews.length > 0 && (
  <section id="reviews" class="py-16 md:py-24 bg-background-alt">
    <div class="container mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-accent mb-8 md:mb-12 text-center">
        Was unsere Gäste sagen
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {reviews.map((review) => (
          <div class="bg-background rounded-lg p-6 flex flex-col">
            <div class="flex items-center gap-1 mb-3">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={`w-5 h-5 ${i < review.rating ? 'text-accent' : 'text-foreground/20'}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-foreground/80 mb-4 flex-1 italic">"{review.text}"</p>
            <div class="flex items-center justify-between text-sm">
              <span class="font-semibold text-foreground">{review.author}</span>
              {review.date && (
                <span class="text-foreground/50">{review.date}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a
          href="https://www.google.com/maps/place/Teddy's+Burger"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-foreground/60 hover:text-accent transition-colors text-sm"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          Mehr Bewertungen auf Google
        </a>
      </div>
    </div>
  </section>
)}
